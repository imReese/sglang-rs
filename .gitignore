# Rust build and debug output
/target/
/debug/
/release/
**/*.rs.bk
*.pdb
*.dSYM/
*.profraw

# Native build output
/build/
/cmake-build-*/
/compile_commands.json

# Test, coverage, and mutation output
**/mutants.out*/
/coverage/
/test-results/
/lcov.info
/tarpaulin-report.html

# Python tooling used by development scripts
__pycache__/
*.py[cod]
/.pytest_cache/
/.mypy_cache/
/.ruff_cache/
/.venv/

# Local environment and runtime output
/.env
/.env.*
!/.env.example
/.cache/
*.log
*.pid
*.trace

# Editors and operating systems
/.idea/
/.vscode/
.DS_Store
*.swp
*.swo
*~

# Local coding-agent instructions, state, and design notes
/AGENTS.md
/CLAUDE.md
/.agents/
/.codex/
/.superpowers/
/docs/superpowers/
/superpowers/
